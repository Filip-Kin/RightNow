{
  "expo": {
    "name": "RightNow",
    "slug": "RightNow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/images/icon-512.png",
    "scheme": "rightnow",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.filipkin.rightnow"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "assets/images/icon-512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.filipkin.rightnow"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "assets/images/icon-512.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "resizeMode": "contain"
        }
      ],
      "expo-status-bar",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "RightNow uses the camera to scan a sign-in QR code from another device."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
