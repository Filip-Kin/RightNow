{
    "compilerOptions": {
        // Enable latest features
        "lib": [
            "ESNext"
        ],
        "target": "ESNext",
        "module": "ESNext",
        "moduleDetection": "force",
        "allowJs": true,
        // Bundler mode
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        // Best practices
        "strict": true,
        "skipLibCheck": true,
        "noFallthroughCasesInSwitch": true,
        // Some stricter flags (disabled by default)
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noPropertyAccessFromIndexSignature": false,
        "types": [
            "bun"
        ],
        "typeRoots": [
            "./node_modules/@types",
            "./src/types"
        ],
        // Project-reference output: the app consumes these .d.ts for end-to-end
        // tRPC types. Bun runs the .ts directly at runtime, so emit declarations
        // only (no JS). composite is required for `tsc -b` references.
        "composite": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
